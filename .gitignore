# ===========================
# Model weights & checkpoints
# ===========================
# The checkpoints/ folder is tracked; .pt files are excluded (too large for git).
# Professor can see the folder structure and which experiments produced checkpoints.
*.pt
*.pth
*.ckpt
*.onnx
*.bin

# ===========================
# MLflow
# ===========================
# mlruns/ is committed so the professor can see all experiment metrics.
# Only the large .pt artifact copies inside mlruns are excluded.
mlruns/**/*.pt
mlruns/**/*.pth
mlartifacts/

